{
  "name": "dux-mea-ban",
  "version": "0.1.0",
  "private": true,
  "description": "Linux-only terminal app for preparing and tracking Instagram legal-report workflows with a Bash TUI and Playwright helpers.",
  "type": "module",
  "scripts": {
    "start": "bash ./report.sh",
    "assist": "node ./scripts/assist.mjs",
    "check-status": "node ./scripts/check-profile-status.mjs",
    "test:report-status": "node ./scripts/test-report-status-lines.mjs && node ./scripts/test-report-status-results.mjs && node ./scripts/test-check-profile-status.mjs"
  },
  "dependencies": {
    "playwright-core": "^1.54.2"
  }
}
